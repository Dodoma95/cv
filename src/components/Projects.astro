---
import type { Translation } from '../i18n/types';

interface Props {
  t: Translation;
}

const { t } = Astro.props;
---

<section class="section" id="projets">
  <p class="eyebrow">{t.projectsTitle}</p>

  <div class="projects">
    {t.projects.map((project) => (
      <div class="card project-card">
        <div class="project-head">
          <span class="project-name">{project.name}</span>
          <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="project-link">
            GitHub ↗
          </a>
        </div>
        <p class="project-desc">{project.description}</p>
        <ul class="project-bullets">
          {project.bullets.map((b) => <li>{b}</li>)}
        </ul>
        <div class="stack-pills">
          {project.stack.map((s) => <span class="pill">{s}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .project-card {
    padding: 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-name {
    font-family: ui-monospace, monospace;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .project-link {
    font-size: 0.72rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent-3);
    padding: 0.18rem 0.55rem;
    border-radius: 5px;
    background: var(--accent-2);
    transition: background 0.15s, color 0.15s;
  }

  .project-link:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .project-desc {
    color: var(--text-2);
    font-size: 0.8rem;
  }

  .project-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
  }

  .project-bullets li {
    color: var(--text-2);
    font-size: 0.76rem;
    padding-left: 0.9rem;
    position: relative;
  }

  .project-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.62rem;
    top: 2px;
  }

  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.2rem;
  }
</style>