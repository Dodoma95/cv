---
import '../styles/global.css';

interface Props {
  lang: string;
  title?: string;
  description?: string;
}

const {
  lang,
  title = 'Dorian Maillard — Backend Engineer Java · Spring Boot',
  description = "8 ans d'expérience backend Java / Spring Boot — APIs REST & GraphQL, modernisation SI, architecture hexagonale. Basé en Île-de-France.",
} = Astro.props;

const canonicalUrl = Astro.url.href;
const ogImage = new URL('/cv/img/social-card.png', Astro.site).href;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Dorian Maillard — Backend Engineer" />

    <!-- Favicon -->
    <link rel="icon" href="/cv/img/favicon/cv.png" type="image/png" />

    <!-- Anti-flash : applique le thème sauvegardé avant le premier rendu -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        document.documentElement.setAttribute('data-theme', saved || 'light');
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>